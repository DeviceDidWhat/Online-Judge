# Frontend production environment.
# VITE_API_URL is baked into the bundle at BUILD time (it's a Vite `import.meta.env`
# value), so it must be set wherever you run `npm run build` / `wrangler deploy`.
#
# Local build:   cp .env.production.example .env.production   (then edit, then build)
# Cloudflare:    set VITE_API_URL in the Workers/Pages build environment variables.
#
# Point it at your backend's PUBLIC HTTPS URL, including the trailing /api.
# No trailing slash after `api`.
VITE_API_URL=https://api.your-domain.com/api