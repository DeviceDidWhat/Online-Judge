# ──────────────────────────────────────────────────────────────────────────────
# Backend production environment.
# Copy this to `.env` ON THE SERVER and fill in real values. Never commit `.env`.
#   cp .env.production.example .env   &&   nano .env
# ──────────────────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=production

# ── Databases ────────────────────────────────────────────────────────────────
# MongoDB MUST be a replica set — the app uses change streams (Submission.watch /
# Contest.watch). MongoDB Atlas (free M0) is a replica set out of the box.
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/online_judge?retryWrites=true&w=majority

# Redis backs the BullMQ judge queue. Upstash / Redis Cloud free tier, or a local
# `redis://127.0.0.1:6379` if you run Redis as a container on the same VM.
REDIS_URL=redis://127.0.0.1:6379

# ── CORS / frontend ──────────────────────────────────────────────────────────
# Exact origin(s) of the deployed frontend. Comma-separate to allow several
# (e.g. apex + www, or a custom domain + the *.workers.dev URL). NO trailing slash.
CLIENT_ORIGIN=https://your-frontend.workers.dev

# ── Auth secrets — CHANGE THESE. Generate with:  openssl rand -hex 48 ─────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Cookies ──────────────────────────────────────────────────────────────────
# Frontend and backend are on DIFFERENT domains, so the refresh-token cookie is
# cross-site: it requires SameSite=None + Secure (and therefore HTTPS on the API).
# If you instead serve both under ONE domain via a reverse proxy, use `lax`.
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
BCRYPT_SALT_ROUNDS=12

# ── Judge worker ─────────────────────────────────────────────────────────────
# Keep this FALSE on the web server process — dedicated worker.js processes do the
# judging (see ecosystem.config.js). Setting it true would make the API box judge too.
JUDGE_WORKER_ENABLED=false
# Each worker.js process auto-assigns a unique id (worker-<pid>); leave unset.
# JUDGE_WORKER_ID=
JUDGE_WORKER_REGION=oracle-free
# Docker containers each judge gets. Keep 1 unless the box has spare CPU/RAM.
JUDGE_WORKER_CONCURRENCY=1
JUDGE_DOCKER_CPUS=1
JUDGE_DOCKER_PIDS_LIMIT=128

# ── Cloudinary (avatar uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI Assistant (Gemini) ────────────────────────────────────────────────────
# Free key from https://aistudio.google.com/apikey. Stays server-side only.
# Leave blank to disable the feature.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
